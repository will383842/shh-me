{
  "expo": {
    "name": "Shh Me",
    "slug": "shh-me",
    "scheme": "shhme",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#DCFB4E"
    },
    "ios": {
      "bundleIdentifier": "com.shhme.app",
      "supportsTablet": false,
      "infoPlist": {
        "CFBundleDevelopmentRegion": "en",
        "CFBundleLocalizations": ["en", "fr"]
      }
    },
    "android": {
      "package": "com.shhme.app",
      "adaptiveIcon": {
        "backgroundColor": "#DCFB4E"
      }
    },
    "locales": {
      "en": "./store/ios/en/metadata.json",
      "fr": "./store/ios/fr/metadata.json"
    },
    "primaryColor": "#DCFB4E",
    "plugins": [
      "expo-secure-store",
      "expo-camera",
      "expo-image",
      "expo-font",
      "expo-localization"
    ]
  }
}
