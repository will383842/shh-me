APP_NAME="Shh Me"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL main
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=shhme
DB_USERNAME=shhme
DB_PASSWORD=secret

# Vault (separate encrypted DB for sender-recipient links)
VAULT_DB_HOST=127.0.0.1
VAULT_DB_PORT=5432
VAULT_DB_DATABASE=shhme_vault
VAULT_DB_USERNAME=shhme
VAULT_DB_PASSWORD=secret
VAULT_ENCRYPTION_KEY=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

# Redis cache (port 6379 — allkeys-lru)
REDIS_CLIENT=phpredis
REDIS_CACHE_HOST=127.0.0.1
REDIS_CACHE_PORT=6379
REDIS_PASSWORD=null

# Redis persistent (port 6380 — appendonly, noeviction)
REDIS_PERSISTENT_HOST=127.0.0.1
REDIS_PERSISTENT_PORT=6380

# Cloudflare R2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_PUBLIC=shhme-public
R2_BUCKET_PRIVATE=shhme-private
R2_ENDPOINT=
R2_REGION=auto

# Moderation AI
OPENAI_API_KEY=

# FFmpeg
FFMPEG_BINARY=ffmpeg

# Mail (Mailpit local)
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@shh-me.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
